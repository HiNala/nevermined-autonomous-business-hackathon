# ─── Nevermined Payments ────────────────────────────────────────────────────
# API key from nevermined.app → Profile → API Keys
# Sandbox keys start with "sandbox:" prefix
NVM_API_KEY=sandbox:your-api-key-here

# Environment: "sandbox" (Arbitrum Sepolia testnet) or "live" (Arbitrum One mainnet)
NVM_ENVIRONMENT=sandbox

# Plan DID — from nevermined.app after creating a pricing plan
# Format: did:nvm:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVM_PLAN_ID=did:nvm:

# Agent DID — from nevermined.app after registering your agent
# Format: did:nvm:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVM_AGENT_ID=did:nvm:

# Seller endpoint — the full URL of the payment-protected POST endpoint
# Must match EXACTLY what you registered in Nevermined (including https://)
# Local dev:    http://localhost:3000/api/agent/research
# Production:   https://your-app.vercel.app/api/agent/research
NVM_SELLER_ENDPOINT=http://localhost:3000/api/agent/research

# ─── App Base URL (for A2A agent card at /.well-known/agent.json) ────────────
# Local dev:    http://localhost:3000
# Production:   https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Nevermined — Agent 1 Overrides (Strategist / Context Builder) ────────────
# Optional: if Agent 1 has its own plan/agent IDs on Nevermined.
# Falls back to NVM_PLAN_ID / NVM_AGENT_ID if not set.
# NVM_PLAN_ID_AGENT1=did:nvm:your-agent1-plan-id
# NVM_AGENT_ID_AGENT1=did:nvm:your-agent1-agent-id

# ─── AI Providers (at least one required for the research agent) ─────────────
OPENAI_API_KEY=sk-...
GOOGLE_AI_KEY=
ANTHROPIC_API_KEY=sk-ant-...

# ─── Web Search & Scraping Tools ─────────────────────────────────────────────
# Exa — Neural search with inline content retrieval (recommended)
# Get your key at https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Apify — Google Search scraper + Website Content Crawler
# Get your token at https://console.apify.com/account#/integrations
APIFY_API_TOKEN=

# If neither is set, falls back to DuckDuckGo + raw HTTP fetch (lower quality).

# ─── ZeroClick AI-Native Ads (optional — in-chat ad monetization) ────────────
# Get your key at: https://developer.zeroclick.ai → App API Keys → Create API Key
# When not set, the /api/ads/offers route returns 204 and no ads are shown.
ZEROCLICK_API_KEY=
