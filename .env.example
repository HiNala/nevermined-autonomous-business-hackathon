# ╔═══════════════════════════════════════════════════════════════════╗
# ║  Auto Business — Environment Variables                          ║
# ║  Copy this file to .env and fill in your real values            ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ─── AI Providers (at least ONE is required) ──────────────────────
# The system auto-selects the first available provider.
# OpenAI is recommended as primary; Gemini and Anthropic are fallbacks.
OPENAI_API_KEY=sk-your-openai-key
GOOGLE_AI_KEY=your-google-ai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ─── Nevermined — Primary Config (Research Agent / Agent 2) ───────
# Get these from https://app.nevermined.app after creating a plan & agent.
# NVM_ENVIRONMENT: sandbox | live | staging_sandbox | staging_live
NVM_API_KEY=nvm-your-nevermined-api-key
NVM_ENVIRONMENT=sandbox
NVM_PLAN_ID=did:nv:your-plan-id
NVM_AGENT_ID=did:nv:your-agent-id
NVM_SELLER_ENDPOINT=http://localhost:3000/api/agent/research

# ─── Nevermined — Agent 1 Overrides (Strategist / Context Builder) ─
# Optional: if Agent 1 has its own plan/agent IDs on Nevermined.
# Falls back to NVM_PLAN_ID / NVM_AGENT_ID if not set.
# NVM_PLAN_ID_AGENT1=did:nv:your-agent1-plan-id
# NVM_AGENT_ID_AGENT1=did:nv:your-agent1-agent-id

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
