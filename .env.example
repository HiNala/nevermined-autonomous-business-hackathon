# ╔═══════════════════════════════════════════════════════════════════╗
# ║  Undermind — Environment Variables                               ║
# ║  Copy this file to .env and fill in your real values            ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ─── AI Providers (at least ONE is required) ──────────────────────
# The system auto-selects the first available provider.
# OpenAI is recommended as primary; Gemini and Anthropic are fallbacks.
OPENAI_API_KEY=sk-your-openai-key
GOOGLE_AI_KEY=your-google-ai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ─── Nevermined — Primary Config (Research Agent / Agent 2) ───────
# Get these from https://app.nevermined.app after creating a plan & agent.
# NVM_ENVIRONMENT: sandbox | live | staging_sandbox | staging_live
NVM_API_KEY=nvm-your-nevermined-api-key
NVM_ENVIRONMENT=sandbox
NVM_PLAN_ID=did:nvm:your-plan-id
NVM_AGENT_ID=did:nvm:your-agent-id
NVM_SELLER_ENDPOINT=http://localhost:3000/api/agent/research

# ─── Nevermined — Agent 1 Overrides (Strategist / Context Builder) ─
# Optional: if Agent 1 has its own plan/agent IDs on Nevermined.
# Falls back to NVM_PLAN_ID / NVM_AGENT_ID if not set.
# NVM_PLAN_ID_AGENT1=did:nvm:your-agent1-plan-id
# NVM_AGENT_ID_AGENT1=did:nvm:your-agent1-agent-id

# ─── Web Search & Scraping Tools ──────────────────────────────────
# Both agents can use Exa and/or Apify for search + content extraction.
# Configure which tool each agent uses via the in-app Settings panel.

# Exa — Neural search with inline content retrieval (recommended)
# Get your key at https://dashboard.exa.ai/api-keys
EXA_API_KEY=your-exa-api-key

# Apify — Google Search scraper + Website Content Crawler
# Get your token at https://console.apify.com/account#/integrations
APIFY_API_TOKEN=apify_api_your-token-here

# If neither is set, falls back to DuckDuckGo + raw HTTP fetch (lower quality).

# ─── ZeroClick Ads (optional) ─────────────────────────────────────
# Contextual ads shown alongside research results.
# ZEROCLICK_API_KEY=your-zeroclick-api-key

# ─── NanoBanana — VISION Agent Image Generation (optional) ────────────────────
# Powers the VISION agent: NanoBanana wraps Gemini image models at lower cost.
# Standard: Gemini 2.5 Flash Image (24 credits/gen, max 72 credits per job)
# Get your API key at https://nanobnana.com/dashboard/api-keys
# Without this key, /api/agents/vision returns a demo placeholder image.
NANOBANANA_API_KEY=your-nanobanana-api-key

# ─── VGS Payments (optional) ─────────────────────────────────────
# Very Good Security — PCI-compliant card collection via secure iframes.
# Get credentials at https://dashboard.verygoodsecurity.com
NEXT_PUBLIC_VGS_VAULT_ID=tnt_your_vault_id
VGS_ENVIRONMENT=sandbox
VGS_PROXY_USERNAME=your_vgs_proxy_username
VGS_PROXY_PASSWORD=your_vgs_proxy_password

# ─── Stripe (required for VGS payments) ─────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ─── Vercel Blob Storage (optional — durable artifact persistence) ───
# Stores generated images and deliverable JSON for permanent access.
# Auto-injected on Vercel when Blob is enabled in the project dashboard.
# Get token: Vercel Dashboard → Storage → Create Blob Store → Tokens
BLOB_READ_WRITE_TOKEN=

# ─── App ────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
